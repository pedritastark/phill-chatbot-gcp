# ====================================
# PHILL - Configuración del Entorno
# ====================================

# Puerto del servidor
PORT=3001

# Entorno de ejecución
NODE_ENV=development

# ====================================
# Twilio - WhatsApp
# ====================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+14155238886

# ====================================
# Google Gemini AI
# ====================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# ====================================
# Logging (opcional)
# ====================================
LOG_LEVEL=info

# ====================================
# Base de datos (opcional)
# ====================================
DB_PATH=./data/phill.db

# ====================================
# Timezone
# ====================================
TZ=America/Bogota

# ====================================
# Frontend URL (for OAuth redirects)
# ====================================
FRONTEND_URL=http://localhost:5173

# ====================================
# Gmail API - Email Integration
# ====================================
# Get credentials from: https://console.cloud.google.com/
# 1. Create project > Enable Gmail API
# 2. Create OAuth 2.0 credentials (Web application)
# 3. Add authorized redirect URI: http://localhost:3001/api/v1/email/callback (or production URL)
GMAIL_CLIENT_ID=your_gmail_client_id_here.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:3001/api/v1/email/callback

# Email Sync Configuration
EMAIL_SYNC_ENABLED=true
EMAIL_SYNC_INTERVAL=30          # Minutes between syncs (15, 30, or 60)
EMAIL_LOOKBACK_DAYS=7           # Days to look back on first sync
EMAIL_MAX_RESULTS=50            # Max emails to fetch per sync
EMAIL_BATCH_SIZE=10             # Max emails to process per sync cycle
